{
	"name": "pasu",
	"private": true,
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"workerd"
		]
	},
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.2",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"test:unit": "vitest",
		"test": "pnpm run test:unit --run && pnpm run test:e2e",
		"test:e2e": "playwright install && playwright test"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.18.4",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"wrangler": "^4.97.0"
	},
	"dependencies": {
		"@simplewebauthn/browser": "^13.3.0",
		"@simplewebauthn/server": "^13.3.2"
	}
}
